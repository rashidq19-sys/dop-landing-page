{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:frontend"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "express-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:server"],
      "port": 3001
    },
    {
      "name": "prod-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "preview", "--port", "4180", "--host", "127.0.0.1", "--strictPort"],
      "port": 4180
    }
  ]
}
